{
  "name": "@birthub/workflows-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/workflows-core/src/index.js",
  "types": "./dist/workflows-core/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/workflows-core/src/index.d.ts",
      "import": "./dist/workflows-core/src/index.js",
      "default": "./dist/workflows-core/src/index.js"
    },
    "./nextjs": {
      "types": "./dist/workflows-core/src/nextjs.d.ts",
      "import": "./dist/workflows-core/src/nextjs.js",
      "default": "./dist/workflows-core/src/nextjs.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --config eslint.config.mjs",
    "lint:strict": "eslint . --config eslint.config.mjs --max-warnings=0",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
