{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ],
    "resolveJsonModule": true,
    "paths": {},
    "noEmit": true,
    "outDir": "dist",
    "declaration": true,
    "composite": true,
    "strict": true
  },
  "include": [
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
