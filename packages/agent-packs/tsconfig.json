{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ],
    "resolveJsonModule": true,
    "paths": {},
    "noEmit": false,
    "outDir": "dist",
    "declaration": true
  },
  "include": [
    "corporate-v1/**/*.ts",
    "executive-premium-v1/**/*.ts",
    "github-agents-v1/**/*.ts",
    "test*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "***.spec.ts",
    "***.spec.ts",
    "***.spec.ts",
    "***.spec.ts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
