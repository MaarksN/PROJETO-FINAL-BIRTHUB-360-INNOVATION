{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": { "@birthub/*": ["../../packages/*", "../packages/*", "./packages/*"] },
    "noImplicitAny": false, "useUnknownInCatchVariables": false, "strict": false, "skipLibCheck": true,

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "types": [
      "node"
    ],
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": true
  },
  "include": [
    "**/*.ts",
    "**/*.json"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
