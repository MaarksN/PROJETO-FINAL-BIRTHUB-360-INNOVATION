{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": { "@birthub/*": ["../../packages/*", "../packages/*", "./packages/*"] },
    "noImplicitAny": false, "useUnknownInCatchVariables": false, "strict": false, "skipLibCheck": true,

    "outDir": "dist",
    "declaration": true,
    "strict": true
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "scripts",
    "load-test"
  ]
}
