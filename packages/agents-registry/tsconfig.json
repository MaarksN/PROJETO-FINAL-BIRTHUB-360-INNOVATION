{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": { "@birthub/*": ["../../packages/*", "../packages/*", "./packages/*"] },
    "noImplicitAny": false, "useUnknownInCatchVariables": false, "strict": false, "skipLibCheck": true,
    "declaration": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",

    "types": ["node"]
  },
  "include": ["./src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
