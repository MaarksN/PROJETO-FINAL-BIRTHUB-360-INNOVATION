{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "verbatimModuleSyntax": true,
    "isolatedModules": true
  },
  "include": [
    "**/*.ts"
  ]
}
