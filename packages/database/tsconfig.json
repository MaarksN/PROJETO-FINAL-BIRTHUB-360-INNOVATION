{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@birthub/config": [
        "../config/dist/index.d.ts"
      ],
      "@birthub/logger": [
        "../logger/dist/index.d.ts"
      ]
    },
    "types": [
      "node"
    ],
    "composite": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "***.spec.ts",
    "dist",
    "node_modules",
    "***.spec.ts",
    "***.spec.ts",
    "***.spec.ts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
