generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String            @id @default(cuid())
  tenantId         String            @unique @default(cuid())
  name             String
  slug             String            @unique
  settings         Json?
  stripeCustomerId String?           @unique @map("stripe_customer_id")
  planId           String?           @map("plan_id")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  memberships      Membership[]
  sessions         Session[]
  agents           Agent[]
  workflows        Workflow[]
  workflowSteps    WorkflowStep[]
  workflowTransitions WorkflowTransition[]
  workflowExecutions WorkflowExecution[]
  stepResults      StepResult[]
  customers        Customer[]
  invites          Invite[]
  subscriptions    Subscription[]
  invoices         Invoice[]
  paymentMethods   PaymentMethod[]
  usageRecords     UsageRecord[]
  billingEvents    BillingEvent[]
  auditLogs        AuditLog[]        @relation("OrganizationAuditLogs")
  quotaUsages      QuotaUsage[]      @relation("OrganizationQuotaUsages")
  apiKeys          ApiKey[]
  loginAlerts      LoginAlert[]
  mfaChallenges    MfaChallenge[]
  jobSecrets       JobSigningSecret[]
  plan             Plan?             @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, slug])
  @@index([stripeCustomerId])
  @@index([planId])
  @@map("organizations")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String
  passwordHash     String            @default("")
  status           UserStatus        @default(ACTIVE)
  suspendedAt      DateTime?
  mfaEnabled       Boolean           @default(false)
  mfaSecret        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  memberships      Membership[]
  sessions         Session[]
  sentInvites      Invite[]          @relation("InviteSender")
  auditLogs        AuditLog[]        @relation("AuditActor")
  apiKeys          ApiKey[]
  mfaRecoveryCodes MfaRecoveryCode[]
  mfaChallenges    MfaChallenge[]
  loginAlerts      LoginAlert[]

  @@map("users")
}

model Membership {
  id             String           @id @default(cuid())
  tenantId       String
  organizationId String
  userId         String
  role           Role
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@map("members")
}

model Session {
  id             String        @id @default(cuid())
  tenantId       String
  token          String        @unique
  refreshTokenHash String?     @unique
  csrfToken      String?
  organizationId String
  userId         String
  expiresAt      DateTime
  refreshExpiresAt DateTime?
  lastActivityAt DateTime      @default(now())
  revokedAt      DateTime?
  replacedBySessionId String?
  ipAddress      String?
  userAgent      String?
  status         SessionStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBySession   Session? @relation("SessionRotation", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  rotatedFromSessions Session[] @relation("SessionRotation")

  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

model ApiKey {
  id             String       @id @default(cuid())
  tenantId       String
  organizationId String
  userId         String
  label          String
  prefix         String
  keyHash        String       @unique
  last4          String
  scopes         String[]
  status         ApiKeyStatus @default(ACTIVE)
  expiresAt      DateTime?
  graceExpiresAt DateTime?
  rotatedFromId  String?
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotatedFrom    ApiKey?      @relation("ApiKeyRotation", fields: [rotatedFromId], references: [id], onDelete: SetNull)
  rotatedTo      ApiKey[]     @relation("ApiKeyRotation")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([organizationId, userId])
  @@map("api_keys")
}

model MfaRecoveryCode {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([tenantId])
  @@map("mfa_recovery_codes")
}

model MfaChallenge {
  id             String       @id @default(cuid())
  tenantId       String
  organizationId String
  userId         String
  tokenHash      String       @unique
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, userId, expiresAt])
  @@map("mfa_challenges")
}

model LoginAlert {
  id             String       @id @default(cuid())
  tenantId       String
  organizationId String
  userId         String
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, userId, createdAt])
  @@map("login_alerts")
}

model JobSigningSecret {
  id             String       @id @default(cuid())
  tenantId       String       @unique
  organizationId String       @unique
  secret         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("job_signing_secrets")
}

model Agent {
  id             String       @id @default(cuid())
  tenantId       String
  organizationId String
  name           String
  status         AgentStatus  @default(ACTIVE)
  config         Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, status])
  @@map("agents")
}

model Workflow {
  id             String              @id @default(cuid())
  tenantId       String
  organizationId String
  name           String
  description    String?
  status         WorkflowStatus      @default(DRAFT)
  version        Int                 @default(1)
  definition     Json?
  triggerType    WorkflowTriggerType @default(MANUAL)
  triggerConfig  Json?
  webhookSecret  String?
  cronExpression String?
  eventTopic     String?
  maxDepth       Int                 @default(50)
  publishedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps          WorkflowStep[]
  transitions    WorkflowTransition[]
  executions     WorkflowExecution[]
  stepResults    StepResult[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, status])
  @@index([tenantId, triggerType])
  @@map("workflows")
}

model WorkflowStep {
  id               String                   @id @default(cuid())
  tenantId         String
  organizationId   String
  workflowId       String
  key              String
  name             String
  type             WorkflowStepType
  config           Json
  onError          WorkflowStepOnError      @default(STOP)
  cacheTTLSeconds  Int?
  timeoutMs        Int                      @default(1000)
  isTrigger        Boolean                  @default(false)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow         Workflow                 @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceTransitions WorkflowTransition[]    @relation("WorkflowTransitionSource")
  targetTransitions WorkflowTransition[]    @relation("WorkflowTransitionTarget")
  results          StepResult[]

  @@unique([workflowId, key])
  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, workflowId])
  @@index([tenantId, type])
  @@map("workflow_steps")
}

model WorkflowTransition {
  id             String                  @id @default(cuid())
  tenantId       String
  organizationId String
  workflowId     String
  sourceStepId   String
  targetStepId   String
  route          WorkflowTransitionRoute @default(ALWAYS)
  createdAt      DateTime                @default(now())
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow       Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceStep     WorkflowStep            @relation("WorkflowTransitionSource", fields: [sourceStepId], references: [id], onDelete: Cascade)
  targetStep     WorkflowStep            @relation("WorkflowTransitionTarget", fields: [targetStepId], references: [id], onDelete: Cascade)

  @@unique([workflowId, sourceStepId, targetStepId, route])
  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, workflowId])
  @@index([tenantId, sourceStepId])
  @@index([tenantId, targetStepId])
  @@map("workflow_transitions")
}

model WorkflowExecution {
  id                    String                  @id @default(cuid())
  tenantId              String
  organizationId        String
  workflowId            String
  status                WorkflowExecutionStatus @default(RUNNING)
  triggerType           WorkflowTriggerType
  triggerPayload        Json?
  dedupeHash            String?
  depth                 Int                     @default(0)
  startedAt             DateTime                @default(now())
  completedAt           DateTime?
  durationMs            Int?
  errorMessage          String?
  resumedFromExecutionId String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  organization          Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow              Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepResults           StepResult[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, workflowId])
  @@index([tenantId, status])
  @@index([tenantId, startedAt])
  @@index([tenantId, dedupeHash])
  @@map("workflow_executions")
}

model StepResult {
  id                 String           @id @default(cuid())
  tenantId           String
  organizationId     String
  workflowId         String
  executionId        String
  stepId             String
  status             StepResultStatus @default(SUCCESS)
  attempt            Int              @default(1)
  input              Json?
  output             Json?
  outputSize         Int              @default(0)
  outputPreview      String?
  externalPayloadUrl String?
  startedAt          DateTime         @default(now())
  finishedAt         DateTime?
  errorMessage       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow           Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  execution          WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  step               WorkflowStep     @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([executionId, stepId, attempt])
  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, executionId])
  @@index([tenantId, workflowId])
  @@index([tenantId, stepId])
  @@index([tenantId, status])
  @@map("step_results")
}

model Customer {
  id             String       @id @default(cuid())
  tenantId       String
  organizationId String
  email          String
  name           String
  status         String
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, status])
  @@map("customers")
}

model Invite {
  id              String       @id @default(cuid())
  tenantId        String
  organizationId  String
  email           String
  token           String       @unique
  role            Role         @default(MEMBER)
  status          InviteStatus @default(PENDING)
  invitedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy       User?        @relation("InviteSender", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, status])
  @@index([expiresAt])
  @@map("invites")
}

model AuditLog {
  id           String       @id @default(cuid())
  tenantId     String
  actorId      String?
  action       String
  entityType   String
  entityId     String
  diff         Json
  ip           String?
  userAgent    String?
  createdAt    DateTime     @default(now())
  organization Organization @relation("OrganizationAuditLogs", fields: [tenantId], references: [tenantId], onDelete: Cascade)
  actor        User?        @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, createdAt])
  @@index([tenantId, actorId])
  @@map("audit_logs")
}

model QuotaUsage {
  id           String            @id @default(cuid())
  tenantId     String
  resourceType QuotaResourceType
  period       String
  count        Int               @default(0)
  limit        Int
  resetAt      DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  organization Organization      @relation("OrganizationQuotaUsages", fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@unique([tenantId, resourceType, period])
  @@index([tenantId])
  @@index([tenantId, id])
  @@index([tenantId, resourceType])
  @@index([tenantId, period])
  @@map("quota_usage")
}

model Plan {
  id               String         @id @default(cuid())
  code             String         @unique
  name             String
  description      String?
  stripeProductId  String?        @unique @map("stripe_product_id")
  stripePriceId    String?        @unique @map("stripe_price_id")
  limits           Json
  monthlyPriceCents Int           @default(0) @map("monthly_price_cents")
  yearlyPriceCents Int?           @map("yearly_price_cents")
  currency         String         @default("usd")
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  organizations    Organization[]
  subscriptions    Subscription[]

  @@index([active])
  @@map("plans")
}

model Subscription {
  id                  String             @id @default(cuid())
  tenantId            String
  organizationId      String
  planId              String
  stripeSubscriptionId String?           @unique @map("stripe_subscription_id")
  stripeCustomerId    String?            @map("stripe_customer_id")
  status              SubscriptionStatus @default(trial)
  currentPeriodEnd    DateTime?          @map("current_period_end")
  canceledAt          DateTime?          @map("canceled_at")
  gracePeriodEndsAt   DateTime?          @map("grace_period_ends_at")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices            Invoice[]
  usageRecords        UsageRecord[]

  @@unique([organizationId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model Invoice {
  id               String      @id @default(cuid())
  tenantId         String
  organizationId   String
  subscriptionId   String?
  stripeInvoiceId  String      @unique @map("stripe_invoice_id")
  status           InvoiceStatus
  currency         String      @default("usd")
  amountDueCents   Int         @default(0) @map("amount_due_cents")
  amountPaidCents  Int         @default(0) @map("amount_paid_cents")
  hostedInvoiceUrl String?     @map("hosted_invoice_url")
  invoicePdfUrl    String?     @map("invoice_pdf_url")
  dueDate          DateTime?   @map("due_date")
  periodStart      DateTime?   @map("period_start")
  periodEnd        DateTime?   @map("period_end")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([organizationId, createdAt])
  @@map("invoices")
}

model PaymentMethod {
  id                    String       @id @default(cuid())
  tenantId              String
  organizationId        String
  stripePaymentMethodId String       @unique @map("stripe_payment_method_id")
  brand                 String?
  last4                 String?
  expMonth              Int?         @map("exp_month")
  expYear               Int?         @map("exp_year")
  isDefault             Boolean      @default(false) @map("is_default")
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([organizationId, isDefault])
  @@map("payment_methods")
}

model UsageRecord {
  id             String       @id @default(cuid())
  tenantId       String
  organizationId String
  subscriptionId String?
  eventId        String       @unique @map("event_id")
  metric         String
  quantity       Int
  unit           String       @default("tokens")
  metadata       Json?
  occurredAt     DateTime     @default(now()) @map("occurred_at")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, metric])
  @@index([organizationId, occurredAt])
  @@map("usage_records")
}

model BillingEvent {
  id            String        @id @default(cuid())
  tenantId      String?
  organizationId String?
  stripeEventId String        @unique @map("stripe_event_id")
  type          String
  payload       Json
  processedAt   DateTime      @default(now()) @map("processed_at")
  createdAt     DateTime      @default(now())
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([organizationId, processedAt])
  @@map("billing_events")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  READONLY
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  REVOKED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AgentStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WorkflowTriggerType {
  MANUAL
  WEBHOOK
  CRON
  EVENT
}

enum WorkflowStepType {
  TRIGGER_WEBHOOK
  TRIGGER_CRON
  TRIGGER_EVENT
  HTTP_REQUEST
  CONDITION
  CODE
  TRANSFORMER
  SEND_NOTIFICATION
  AGENT_EXECUTE
  AI_TEXT_EXTRACT
  DELAY
}

enum WorkflowStepOnError {
  STOP
  CONTINUE
}

enum WorkflowTransitionRoute {
  ALWAYS
  IF_TRUE
  IF_FALSE
  ON_SUCCESS
  ON_FAILURE
  FALLBACK
}

enum WorkflowExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
  WAITING
}

enum StepResultStatus {
  SUCCESS
  FAILED
  SKIPPED
  WAITING
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum SubscriptionStatus {
  trial
  active
  past_due
  canceled
  paused
}

enum InvoiceStatus {
  draft
  open
  paid
  uncollectible
  void
  past_due
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum QuotaResourceType {
  EMAILS_SENT
  AI_PROMPTS
  WORKFLOW_RUNS
  STORAGE_GB
  API_REQUESTS
}
