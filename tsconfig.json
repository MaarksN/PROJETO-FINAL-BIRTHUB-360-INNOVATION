{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "paths": { "@birthub/*": ["../../packages/*", "../packages/*", "./packages/*"] },
    "noImplicitAny": false, "useUnknownInCatchVariables": false, "strict": false, "skipLibCheck": true,

    "allowJs": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "node",
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/.next/**",
    ".pytest_cache",
    ".tools",
    "audit",
    "dist",
    "build",
    ".turbo"
  ]
}
