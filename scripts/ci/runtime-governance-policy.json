            "config-defined"
          ],
          "name": "webhooks",
          "path": "apps/api/src/modules/webhooks/router.ts"
        }
      ],
      "operationalRoutes": [
        "/api/openapi.json",
        "/api/docs",
        "/metrics",
        "/api/v1/metrics",
        "/health",
        "/api/v1/health",
        "/health/deep",
        "/api/v1/health/deep",
        "/health/readiness",
        "/api/v1/health/readiness"
      ]
    },
    "compatOnly": [
      {
        "kind": "delegating-wrapper",
        "path": "apps/api/src/app/auth-routes.ts",
        "reason": "Legacy registration helper that delegates to modular auth mounting and remains outside createApp() runtime."
      },
      {
        "kind": "delegating-wrapper",
        "path": "apps/api/src/app/auth-and-core-routes.ts",
        "reason": "Internal compatibility wrapper preserved outside the real bootstrap path."
      }
    ],
    "parked": [
      {
        "kind": "not-mounted-module",
        "path": "apps/api/src/modules/clinical/router.ts",
        "reason": "Clinical domain remains outside the real bootstrap and may only be reactivated by explicit decision."
      },
      {
        "kind": "not-mounted-module",
        "path": "apps/api/src/modules/fhir/router.ts",
        "reason": "FHIR facade remains outside the real bootstrap and may only be reactivated by explicit decision."
      }
    ],
    "operationalOnly": [
      {
        "kind": "entrypoint",
        "path": "apps/api/src/server.ts",
        "reason": "Thin process entrypoint that starts the API runtime."
      },
      {
        "kind": "lifecycle",
        "path": "apps/api/src/app.ts",
        "reason": "Owns listen, shutdown and observability initialization, not modular route ownership."
      },
      {
        "kind": "side-effect-registration",
        "path": "apps/api/src/app/core.ts",
        "reason": "Owns cache initialization, tenant cache invalidation, privacy retention scheduling and workflow internal event bridge setup."
      },
      {
        "kind": "special-route-pipeline",
        "path": "apps/api/src/app/core.ts",
        "reason": "Owns webhook-special handling for Stripe before the main application route surface."
      }
    ]
  },
  "typedExceptionGovernance": {
    "primaryBaseline": {
      "description": "The primary baseline tracks only debt that matters to the mounted runtime and explicitly classified exceptions.",
      "runtimeMountedSourceRoots": [
        "apps/api/src"
      ],
      "runtimeMountedSourceExemptions": [
        "apps/api/src/app/auth-routes.ts",
        "apps/api/src/app/auth-and-core-routes.ts",
        "apps/api/src/modules/clinical/**",
        "apps/api/src/modules/fhir/**"
      ],
      "rules": {
        "allowClassifiedCompatOnlyDebt": true,
        "allowClassifiedParkedDebt": true,
        "forbidNewDirectivesInMountedRuntime": true
      }
    },
    "secondaryOperationalLayers": [
      {
        "classification": "operational-second-layer",
        "path": "packages/database/src/**",
        "reason": "Operationally important source, but outside the mounted API hot path."
      },
      {
        "classification": "operational-second-layer",
        "path": "packages/queue/src/**",
        "reason": "Operationally important source, but outside the mounted API hot path."
      }
    ],
    "separateTracks": [
      {
        "classification": "test",
        "path": "apps/api/test/**"
      },
      {
        "classification": "test",
        "path": "apps/api/tests/**"
      },
      {
        "classification": "test",
        "path": "packages/**/test/**"
      },
      {
        "classification": "test",
        "path": "packages/**/tests/**"
      },
      {
        "classification": "test",
        "path": "tests/**"
      },
      {
        "classification": "script",
        "path": "scripts/**"
      },
      {
        "classification": "script",
        "path": "packages/database/scripts/**"
      },
      {
        "classification": "script",
        "path": "packages/queue/scripts/**"
      },
      {
        "classification": "script",
        "path": "packages/queue/load-test/**"
      }
    ],
    "excludedFromPrimaryBaseline": [
      "**/dist/**",
      "**/generated/**",
      "**/gen/**",
      "**/coverage/**",
      "artifacts/**"
    ]
  },
  "loggingGovernance": {
    "categories": [
      "request",
      "error",
      "operation",
      "domain"
    ],
    "minimumContext": {
      "domain": [
        "component"
      ],
      "error": [
        "error.name",
        "error.message"
      ],
      "operation": [
        "component",
        "action",
        "status"
      ],
      "request": [
        "requestId",
        "traceId",
        "method",
        "path",
        "statusCode",
        "durationMs"
      ]
    },
    "rules": {
      "compatibilityScriptsMustAvoidConsole": true,
      "errorLogMustClassifyFailure": true,
      "healthLogsOnlyOnDegradedOrDown": true,
      "loggerNameMustReflectOwningComponent": true,
      "requestAndErrorLogsMustNotOverlapRoles": true
    }
  },
  "ciIntent": {
    "requiredChecks": [
      "typecheck:policy",
      "ci:runtime-governance"
    ],
    "plannedScripts": [
      "ci:runtime-governance"
    ],
    "rules": {
      "blockSilentPromotionOfParkedSurfaces": true,
      "blockWrappersEnteringMountedBootstrap": true,
      "preserveRuntimeCanonicalSourceOfTruth": true
    }
  }
}
