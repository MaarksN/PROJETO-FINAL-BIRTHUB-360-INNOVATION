          "path": "apps/api/src/modules/organizations/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1/packs"
          ],
          "name": "packs",
          "path": "apps/api/src/modules/packs/pack-installer-routes.ts"
        },
        {
          "mountPaths": [
            "/api/v1/outputs"
          ],
          "name": "outputs",
          "path": "apps/api/src/modules/outputs/output-routes.ts"
        },
        {
          "mountPaths": [
            "/api/v1/privacy"
          ],
          "name": "privacy",
          "path": "apps/api/src/modules/privacy/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1"
          ],
          "name": "search",
          "path": "apps/api/src/modules/search/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1"
          ],
          "name": "users",
          "path": "apps/api/src/modules/users/router.ts"
