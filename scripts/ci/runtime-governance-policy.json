          "path": "apps/api/src/modules/agents/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1/analytics"
          ],
          "name": "analytics",
          "path": "apps/api/src/modules/analytics/router.ts"
        },
        {
          "mountPaths": [
            "config-defined"
          ],
          "name": "dashboard",
          "path": "apps/api/src/modules/dashboard/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1/connectors"
          ],
          "name": "connectors",
          "path": "apps/api/src/modules/connectors/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1"
          ],
          "name": "conversations",
          "path": "apps/api/src/modules/conversations/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1/agents",
            "/api/v1/marketplace"
          ],
          "name": "marketplace",
          "path": "apps/api/src/modules/marketplace/marketplace-routes.ts"
        },
        {
          "mountPaths": [
            "/api/v1/billing"
          ],
          "name": "billing",
          "path": "apps/api/src/modules/billing/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1/budgets"
          ],
          "name": "budget",
          "path": "apps/api/src/modules/budget/budget-routes.ts"
        },
        {
          "mountPaths": [
            "/api/v1"
          ],
          "name": "feedback",
          "path": "apps/api/src/modules/feedback/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1"
          ],
          "name": "invites",
          "path": "apps/api/src/modules/invites/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1"
          ],
          "name": "notifications",
          "path": "apps/api/src/modules/notifications/router.ts"
        },
        {
          "mountPaths": [
            "/api/v1"
