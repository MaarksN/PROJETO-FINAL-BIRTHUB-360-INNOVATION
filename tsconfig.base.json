{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "strict": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@birthub/agents-core/policy": [
        "packages/agents-core/src/policy/engine.ts"
      ],
      "@birthub/agents-core/tools": [
        "packages/agents-core/src/tools/index.ts"
      ],
      "@birthub/utils/fetch": [
        "packages/utils/src/fetch.ts"
      ],
      "@birthub/*": [
        "packages/*/src/index.ts",
        "packages/*/src"
      ],
      "@birthub/api/modules/outputs/output-service": [
        "apps/api/src/modules/outputs/output.service.d.ts"
      ],
      "@birthub/api/modules/agents/metrics-service": [
        "apps/api/src/modules/agents/metrics.service.d.ts"
      ]
    }
  }
}
