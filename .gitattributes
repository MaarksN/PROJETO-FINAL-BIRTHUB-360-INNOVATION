* text=auto

# Arquivos TypeScript e Javascript (usar formato UNIX/LF)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.jsx text eol=lf

# JSON e Configurações
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Shell e Scripts (Unix LF)
*.sh text eol=lf
*.py text eol=lf

# Scripts Windows (CRLF)
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binários que não recebem EOL config
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
