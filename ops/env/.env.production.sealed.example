# Sealed equivalent for .env.production
# Keep real values only in GitHub Environment secrets/variables or vault.

NODE_ENV=production
DEPLOYMENT_ENVIRONMENT=production
NEXT_PUBLIC_ENVIRONMENT=production
LOG_LEVEL=info

NEXT_PUBLIC_APP_URL=https://app.birthhub360.com
NEXT_PUBLIC_API_URL=https://api.birthhub360.com
WEB_BASE_URL=https://app.birthhub360.com
API_CORS_ORIGINS=https://app.birthhub360.com

NEXT_PUBLIC_CSP_REPORT_ONLY=false
REQUIRE_SECURE_COOKIES=true

NEXT_PUBLIC_SENTRY_DSN=https://sealed-public-production@example.ingest.sentry.io/2001
SENTRY_DSN=https://sealed-backend-production@example.ingest.sentry.io/2002
SENTRY_ENVIRONMENT=production

DATABASE_URL=postgresql://sealed_user:sealed_password@production-postgres.internal:5432/birthub?sslmode=require
REDIS_URL=rediss://sealed_user:sealed_password@production-redis.internal:6379

SESSION_SECRET=sealed_production_session_secret_64_chars_minimum_value_xxxxxxxx
SESSION_IP_HASH_SALT=sealed_production_session_ip_hash_salt_64_chars_minimum_x
AUTH_MFA_ENCRYPTION_KEY=sealed_production_mfa_encryption_key_64_chars_minimum_xx
JOB_HMAC_GLOBAL_SECRET=sealed_production_job_hmac_secret_64_chars_minimum_value

