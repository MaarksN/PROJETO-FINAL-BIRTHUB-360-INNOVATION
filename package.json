{
  "name": "birthub-360",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "pnpm build:core",
    "build:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing run build",
    "build:satellites": "node scripts/ci/run-satellites.mjs build",
    "bootstrap:local:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap/bootstrap-local.ps1",
    "bootstrap:node:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap/install-node-portable.ps1",
    "ci:core": "node scripts/ci/full.mjs task core",
    "ci:dirty-tree": "node scripts/ci/check-dirty-tree.mjs",
    "ci:full": "node scripts/ci/full.mjs full",
    "ci:legacy-agents": "node scripts/ci/full.mjs task legacy-agents",
    "ci:security-guardrails": "pnpm workspace:audit && pnpm --filter @birthub/config test && pnpm security:guards && pnpm --filter @birthub/api typecheck && pnpm --filter @birthub/api test && pnpm --filter @birthub/database test && pnpm --filter @birthub/database db:migrate:deploy",
    "ci:satellites": "node scripts/ci/full.mjs task satellites",
    "dev": "turbo run dev --filter=@birthub/web --filter=@birthub/api --filter=@birthub/worker --parallel",
    "dev:legacy": "turbo run dev",
    "stack:canonical": "pnpm preflight:core && pnpm dev",
    "stack:hybrid": "pnpm preflight:full && pnpm dev:legacy",
    "lint": "pnpm lint:core",
    "lint:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing... --filter=@birthub/auth... --filter=@birthub/db... --filter=@birthub/utils... run lint",
    "lint:satellites": "node scripts/ci/run-satellites.mjs lint",
    "preflight:agents": "node scripts/ci/preflight.mjs agents",
    "preflight:core": "node scripts/ci/preflight.mjs core",
    "preflight:full": "node scripts/ci/preflight.mjs full",
    "preflight:satellites": "node scripts/ci/preflight.mjs satellites",
    "preflight:workflow-suite": "node scripts/ci/preflight.mjs workflow-suite",
    "typecheck": "pnpm typecheck:core",
    "typecheck:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing... --filter=@birthub/auth... --filter=@birthub/db... --filter=@birthub/utils... run typecheck",
    "typecheck:satellites": "node scripts/ci/run-satellites.mjs typecheck",
    "test": "pnpm test:core",
    "test:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing... --filter=@birthub/auth... --filter=@birthub/db... --filter=@birthub/utils... run test",
    "test:satellites": "node scripts/ci/run-satellites.mjs test",
    "test:isolation": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/api --filter=@birthub/worker run test:isolation",
    "test:workflows": "pnpm --filter @birthub/workflows-core test && pnpm --filter @birthub/worker test && pnpm workflow:coverage",
    "workflow:coverage": "node --import tsx scripts/verify-workflow-step-coverage.ts",
    "test:auth": "pnpm --filter @birthub/api test:auth",
    "test:rbac": "pnpm --filter @birthub/api test:rbac",
    "test:security": "pnpm --filter @birthub/api test:security",
    "security:report": "tsx scripts/security/generate-security-report.ts",
    "security:guards": "tsx scripts/security/check-auth-guards.ts",
    "packs:validate": "pnpm --filter @birthub/agent-packs validate",
    "packs:test": "pnpm --filter @birthub/agent-packs test",
    "packs:smoke": "pnpm --filter @birthub/agent-packs smoke",
    "packs:regression": "pnpm --filter @birthub/agent-packs regression",
    "packs:docs": "pnpm --filter @birthub/agent-packs docs",
    "packs:qa-report": "node --import tsx scripts/pack-qa-report.ts",
    "format": "prettier --write .",
    "lint:workflows": "pnpm --filter @birthub/workflows-core exec eslint . --config eslint.config.mjs --max-warnings=0",
    "db:generate": "pnpm --filter @birthub/database db:generate",
    "db:migrate": "pnpm --filter @birthub/database db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @birthub/database db:migrate:deploy",
    "db:reset": "pnpm --filter @birthub/database db:reset",
    "db:seed": "pnpm --filter @birthub/database db:seed",
    "billing:sync": "pnpm --filter @birthub/api billing:sync",
    "privacy:verify": "tsx scripts/privacy/verify-anonymization.ts",
    "release:migrate": "tsx scripts/release/final-data-migration.ts",
    "release:preflight:production": "node --import tsx scripts/release/preflight-env.ts --target=production",
    "release:preflight:staging": "node --import tsx scripts/release/preflight-env.ts --target=staging",
    "release:smoke": "tsx scripts/release/global-smoke.ts",
    "ops:vps:env": "node scripts/ops/generate-vps-env.mjs",
    "ops:vps:preflight": "node --import tsx scripts/release/preflight-env.ts --target=production --env-file=.env.vps",
    "setup:local": "bash ./scripts/setup/setup-local.sh",
    "reset:local": "bash ./scripts/reset-local.sh",
    "clean": "node scripts/clean.mjs",
    "ci:task": "node scripts/ci/full.mjs task",
    "agent:snapshot": "node scripts/agent/generate-snapshot.mjs",
    "postinstall": "node scripts/postinstall-db-generate.mjs",
    "test:e2e": "playwright test",
    "test:e2e:release": "playwright test tests/e2e/release-master.spec.ts",
    "test:workflows:evidence": "playwright test tests/e2e/workflow-editor-evidence.spec.ts",
    "test:billing:coverage": "node --import tsx scripts/billing/generate-billing-coverage-report.ts",
    "test:agents": "pytest agents tests/integration -n auto --dist loadfile",
    "test:coverage": "pytest agents tests/integration -n auto --dist loadfile --cov=agents/ae --cov=agents/ldr --cov=agents/sdr --cov=agents/shared --cov-fail-under=80",
    "test:load:k6": "k6 run scripts/load-tests/stress.js",
    "test:worker:overload": "tsx scripts/load-tests/worker-overload.ts",
    "test:load": "pnpm --filter @birthub/queue test:load",
    "smoke:satellites": "node scripts/ci/run-satellites.mjs smoke",
    "dev:ldr-worker": "tsx agents/ldr/worker.ts",
    "dev:sdr-worker": "tsx agents/sdr/worker.ts",
    "dev:financeiro-worker": "tsx agents/financeiro/worker.ts",
    "dev:juridico-worker": "tsx agents/juridico/worker.ts",
    "dev:analista-worker": "tsx agents/analista/worker.ts",
    "dev:pos-venda-worker": "tsx agents/pos_venda/worker.ts",
    "dev:all-workers": "pnpm -r --parallel --filter \"*-agent-worker\" dev",
    "dev:ae-worker": "tsx agents/ae/worker.ts",
    "dev:marketing-worker": "tsx agents/marketing/worker.ts",
    "ci:local": "bash ./scripts/ci/local-ci.sh",
    "workspace:audit": "node scripts/ci/workspace-audit.mjs",
    "monorepo:doctor": "node scripts/ci/monorepo-doctor.mjs",
    "release:scorecard": "node scripts/ci/release-scorecard.mjs",
    "prepare": "husky",
    "test:db:baseline": "node --import tsx scripts/performance/database-baseline.mjs",
    "docs:links": "node scripts/docs/check-doc-links.mjs",
    "docs:dependency-graph": "node scripts/docs/generate-dependency-graph.mjs",
    "docs:health": "node scripts/docs/generate-technical-health-dashboard.mjs",
    "docs:changelog:init": "node scripts/docs/bootstrap-changelogs.mjs",
    "docs:verify": "pnpm docs:links && pnpm docs:dependency-graph && pnpm docs:health",
    "coverage:check": "node scripts/coverage/check.mjs",
    "coverage:baseline:update": "node scripts/coverage/check.mjs --write-baseline",
    "test:contracts": "node scripts/ci/run-pnpm.mjs --filter @birthub/api-gateway test:contract",
    "test:python:integration": "pytest tests/integration -n auto --dist loadfile",
    "test:python:coverage": "pytest agents tests/integration -n auto --dist loadfile --cov=agents/ae --cov=agents/ldr --cov=agents/sdr --cov=agents/shared --cov-fail-under=80",
    "test:tag:unit": "node scripts/testing/run-tagged-tests.mjs unit",
    "test:tag:integration": "node scripts/testing/run-tagged-tests.mjs integration",
    "test:tag:slow": "node scripts/testing/run-tagged-tests.mjs slow",
    "test:shard": "node scripts/testing/run-shard.mjs",
    "test:traceability": "node scripts/testing/generate-traceability-report.mjs",
    "report:performance": "node scripts/testing/generate-performance-report.mjs",
    "report:regression-zero": "node scripts/testing/generate-regression-zero-report.mjs",
    "db:check:all": "pnpm --filter @birthub/database db:check:all",
    "db:seed:ci": "pnpm --filter @birthub/database db:seed:ci",
    "db:seed:smoke": "pnpm --filter @birthub/database db:seed:smoke",
    "db:seed:staging": "pnpm --filter @birthub/database db:seed:staging",
    "db:validate:pr": "pnpm --filter @birthub/database db:validate:pr"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "agents/*"
  ],
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.6",
      "flatted": ">=3.4.2"
    }
  },
  "dependencies": {
    "@types/opossum": "^8.1.9",
    "fast-xml-parser": "5.5.6",
    "lru-cache": "^11.2.7",
    "opossum": "^9.0.0",
    "zod": "^4.3.6"
  }
}
