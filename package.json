{
  "name": "birthub-360",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "9.1.0"
  },
  "scripts": {
    "artifacts:clean": "node scripts/ci/cleanup-artifacts.mjs",
    "branch:check": "node scripts/ci/check-branch-name.mjs",
    "build": "pnpm db:generate && pnpm build:core && pnpm release:sbom",
    "build:agents": "node scripts/ci/run-pnpm.mjs -r --if-present --filter \"*-agent-worker\" run build",
    "build:core": "node scripts/ci/run-pnpm.mjs -r --workspace-concurrency=1 --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing run build",
    "build:workspace": "turbo run build",
    "build:satellites": "node scripts/ci/run-satellites.mjs build",
    "bootstrap:local:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap/bootstrap-local.ps1",
    "bootstrap:node:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap/install-node-portable.ps1",
    "ci:commitlint": "node scripts/ci/check-commit-messages.mjs",
    "ci:core": "node scripts/ci/full.mjs task core",
    "ci:active-product-capabilities": "node scripts/ci/check-active-product-capabilities-alignment.mjs",
    "ci:default-e2e-surface-freeze": "node scripts/ci/check-default-e2e-surface-freeze.mjs",
    "ci:dirty-tree": "node scripts/ci/check-dirty-tree.mjs",
    "ci:full": "node scripts/ci/full.mjs full",
    "ci:legacy-db-surface-freeze": "node scripts/ci/check-legacy-db-surface-freeze.mjs",
    "ci:legacy-runtime-surface-freeze": "node scripts/ci/check-legacy-runtime-surface-freeze.mjs",
    "ci:web-inline-style-freeze": "node scripts/ci/check-web-inline-style-freeze.mjs",
    "ci:lockfile": "node scripts/ci/lockfile-governance.mjs",
    "ci:security-guardrails": "node scripts/ci/security-guardrails-local.mjs",
    "ci:security-guardrails:strict": "node scripts/ci/security-guardrails-local.mjs --require-db",
    "ci:security-guardrails:local": "node scripts/ci/security-guardrails-local.mjs",
    "ci:satellites": "node scripts/ci/full.mjs task satellites",
    "dev": "turbo run dev --filter=@birthub/web --filter=@birthub/api --filter=@birthub/worker --parallel",
    "dev:legacy": "node scripts/legacy/block-legacy-entrypoint.mjs dev:legacy",
    "commits:check": "node scripts/ci/check-commit-messages.mjs",
    "docs:check-links": "node scripts/docs/check-doc-links.mjs",
    "stack:canonical": "pnpm preflight:core && pnpm dev",
    "stack:hybrid": "node scripts/legacy/block-legacy-entrypoint.mjs stack:hybrid",
    "hygiene:check": "node scripts/ci/repo-hygiene.mjs",
    "audit:f2:db-imports": "node scripts/diagnostics/audit-legacy-db-imports.mjs",
    "audit:materialize:doc-only": "node scripts/diagnostics/materialize-doc-only-controls.mjs",
    "audit:ownership": "node scripts/diagnostics/check-ownership-governance.mjs",
    "audit:batch:logical": "node scripts/forensics/materialize-logical-batch.mjs",
    "audit:materialize:all": "pnpm audit:materialize:doc-only && pnpm audit:f2:db-imports && pnpm audit:ownership",
    "audit:prepare": "node scripts/audit/prepare-history.mjs",
    "audit:generate": "node scripts/audit/generate-report.mjs",
    "audit:run": "node scripts/audit/prepare-history.mjs && node scripts/audit/generate-report.mjs",
    "audit:td-catalog": "node scripts/audit/reconcile-td-catalog.mjs",
    "audit:prime:refresh-evidence": "node scripts/audit/prime-refresh-evidence.mjs",
    "audit:prime:collect": "node scripts/audit/prime-refresh-evidence.mjs && node scripts/audit/prime-collect.mjs && node scripts/audit/prime-normalize.mjs && node scripts/audit/prime-score.mjs",
    "audit:prime:render": "node scripts/audit/prime-render.mjs",
    "audit:prime:verify": "node scripts/audit/prime-verify.mjs",
    "audit:prime:backlog": "node scripts/audit/prime-backlog.mjs",
    "audit:prime": "node scripts/audit/prime-refresh-evidence.mjs && node scripts/audit/prime-collect.mjs && node scripts/audit/prime-normalize.mjs && node scripts/audit/prime-score.mjs && node scripts/audit/prime-render.mjs && node scripts/audit/prime-verify.mjs && node scripts/audit/prime-backlog.mjs",
    "audit:agents:governance": "node scripts/audit/executive-agents-governance.mjs",
    "lint": "pnpm lint:policy && pnpm lint:core",
    "lint:policy": "node scripts/ci/lint-policy.mjs",
    "lint:agents": "node scripts/ci/run-pnpm.mjs -r --if-present --filter \"*-agent-worker\" run lint",
    "lint:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing... --filter=@birthub/auth... --filter=@birthub/utils... run lint",
    "lint:satellites": "node scripts/ci/run-satellites.mjs lint",
    "lint:workspace": "turbo run lint",
    "preflight:agents": "node scripts/ci/preflight.mjs agents",
    "preflight:core": "node scripts/ci/preflight.mjs core",
    "preflight:full": "node scripts/ci/preflight.mjs full",
    "preflight:satellites": "node scripts/ci/preflight.mjs satellites",
    "preflight:workflow-suite": "node scripts/ci/preflight.mjs workflow-suite",
    "typecheck": "pnpm typecheck:policy && pnpm typecheck:core",
    "typecheck:policy": "node scripts/ci/ts-directives-guard.mjs",
    "typecheck:agents": "node scripts/ci/run-pnpm.mjs -r --if-present --filter \"*-agent-worker\" run typecheck",
    "typecheck:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing... --filter=@birthub/auth... --filter=@birthub/utils... run typecheck",
    "typecheck:satellites": "node scripts/ci/run-satellites.mjs typecheck",
    "typecheck:workspace": "turbo run typecheck",
    "test": "pnpm test:core",
    "test:agents:packages": "node scripts/ci/run-pnpm.mjs -r --if-present --filter \"*-agent-worker\" run test",
    "test:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing... --filter=@birthub/auth... --filter=@birthub/utils... run test",
    "test:integration": "pnpm --filter @birthub/api exec node --import tsx --test test/performance.test.ts apps/api/tests/workflow-retry-lineage.integration.test.ts && pnpm --filter @birthub/worker exec node --import tsx --test src/runtime.integration.test.ts src/agents/runtime.db-integration.test.ts src/engine/runner.db-integration.test.ts",
    "test:satellites": "node scripts/ci/run-satellites.mjs test",
    "test:workspace": "turbo run test",
    "test:isolation": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/api --filter=@birthub/worker run test:isolation",
    "test:workflows": "pnpm --filter @birthub/workflows-core test && pnpm --filter @birthub/worker test && pnpm workflow:coverage",
    "workflow:coverage": "node --import tsx scripts/verify-workflow-step-coverage.ts",
    "test:auth": "pnpm --filter @birthub/api test:auth",
    "test:rbac": "pnpm --filter @birthub/api test:rbac",
    "test:security": "pnpm --filter @birthub/api test:security",
    "security:report": "tsx scripts/security/generate-security-report.ts",
    "security:guards": "pnpm exec tsx scripts/security/check-auth-guards.ts",
    "security:inline-credentials": "node scripts/security/scan-inline-credentials.mjs",
    "packs:validate": "pnpm --filter @birthub/agent-packs validate",
    "agents:compile:github": "node --import tsx scripts/agent/compile-github-agents.ts",
    "agents:readiness:github": "node --import tsx scripts/agent/check-github-agent-readiness.ts",
    "agents:industrialize:github": "pnpm agents:compile:github && pnpm agents:readiness:github",
    "packs:test": "pnpm --filter @birthub/agent-packs test",
    "packs:smoke": "pnpm --filter @birthub/agent-packs smoke",
    "packs:regression": "pnpm --filter @birthub/agent-packs regression",
    "packs:docs": "pnpm --filter @birthub/agent-packs docs",
    "packs:qa-report": "node --import tsx scripts/pack-qa-report.ts",
    "format": "prettier --write .",
    "lint:workflows": "pnpm --filter @birthub/workflows-core exec eslint . --config eslint.config.mjs --max-warnings=0",
    "db:generate": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:generate",
    "db:bootstrap:ci": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:bootstrap:ci",
    "db:migrate": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:migrate:dev",
    "db:migrate:deploy": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:migrate:deploy",
    "db:reset": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:reset",
    "db:seed": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:seed",
    "billing:sync": "pnpm --filter @birthub/api billing:sync",
    "privacy:verify": "tsx scripts/privacy/verify-anonymization.ts",
    "release:migrate": "tsx scripts/release/final-data-migration.ts",
    "release:preflight:production": "node --import tsx scripts/release/preflight-env.ts --target=production",
    "release:preflight:staging": "node --import tsx scripts/release/preflight-env.ts --target=staging --env-file=ops/release/sealed/.env.staging.sealed",
    "release:smoke": "tsx scripts/release/global-smoke.ts",
    "ops:backup:health": "node --import tsx scripts/ops/check-backup-health.ts",
    "ops:dr:record": "node --import tsx scripts/ops/record-disaster-recovery-drill.ts",
    "ops:dr:record:auto": "node --import tsx scripts/ops/record-disaster-recovery-drill-auto.ts",
    "ops:dr:report": "node --import tsx scripts/ops/generate-disaster-recovery-report.ts",
    "ops:vps:env": "node scripts/ops/generate-vps-env.mjs",
    "ops:vps:preflight": "node --import tsx scripts/release/preflight-env.ts --target=production --env-file=.env.vps",
    "setup:local": "bash ./scripts/setup/setup-local.sh",
    "reset:local": "bash ./scripts/reset-local.sh",
    "clean": "node scripts/clean.mjs",
    "lockfile:hash:update": "node scripts/ci/write-lockfile-hash.mjs",
    "ci:task": "node scripts/ci/full.mjs task",
    "agent:snapshot": "node scripts/agent/generate-snapshot.mjs",
    "postinstall": "node scripts/postinstall-db-generate.mjs",
    "test:e2e": "playwright test",
    "test:e2e:release": "playwright test tests/e2e/release-master.spec.ts",
    "test:workflows:evidence": "playwright test tests/e2e/workflow-editor-evidence.spec.ts",
    "test:billing:coverage": "node --import tsx scripts/billing/generate-billing-coverage-report.ts",
    "test:python": "pytest apps/webhook-receiver/tests -n auto --dist loadfile",
    "test:load:k6": "k6 run scripts/load-tests/stress.js",
    "test:worker:overload": "tsx scripts/load-tests/worker-overload.ts",
    "test:load": "pnpm --filter @birthub/queue test:load",
    "coverage:dashboard": "node scripts/coverage/render-dashboard.mjs",
    "coverage:check": "pnpm coverage:dashboard && node scripts/coverage/check.mjs",
    "quality:complexity": "node scripts/quality/generate-cyclomatic-baseline.mjs",
    "quality:web-bundle": "node scripts/quality/generate-web-bundle-baseline.mjs",
    "quality:dead-code": "node scripts/quality/check-dead-code.mjs",
    "quality:dead-code:satellites": "node scripts/ci/run-pnpm.mjs exec knip --config knip.satellites.json",
    "test:mutation:run": "node scripts/quality/run-mutation-suite.mjs",
    "quality:mutation:evidence": "node scripts/quality/generate-mutation-evidence.mjs",
    "test:mutation": "node scripts/quality/run-stryker.mjs run",
    "smoke:satellites": "node scripts/ci/run-satellites.mjs smoke",
    "dev:all-workers": "pnpm -r --parallel --filter \"*-agent-worker\" dev",
    "ci:local": "bash ./scripts/ci/local-ci.sh",
    "workspace:audit": "node scripts/ci/workspace-audit.mjs && node scripts/ci/script-compliance-audit.mjs",
    "monorepo:doctor": "node scripts/ci/monorepo-doctor.mjs",
    "release:scorecard": "node scripts/ci/release-scorecard.mjs",
    "prepare": "husky",
    "test:db:baseline": "node --import tsx scripts/performance/database-baseline.mjs",
    "docs:links": "node scripts/docs/check-doc-links.mjs",
    "docs:dependency-graph": "node scripts/docs/generate-dependency-graph.mjs",
    "docs:health": "node scripts/docs/generate-technical-health-dashboard.mjs",
    "docs:changelog:init": "node scripts/docs/bootstrap-changelogs.mjs",
    "docs:verify": "pnpm docs:links && pnpm docs:dependency-graph && pnpm docs:health",
    "test:python:integration": "pytest apps/webhook-receiver/tests -n auto --dist loadfile",
    "test:python:coverage": "pytest apps/webhook-receiver/tests -n auto --dist loadfile --cov=apps/webhook-receiver --cov-fail-under=75",
    "test:tag:unit": "node scripts/testing/run-tagged-tests.mjs unit",
    "test:tag:integration": "node scripts/testing/run-tagged-tests.mjs integration",
    "test:tag:slow": "node scripts/testing/run-tagged-tests.mjs slow",
    "test:shard": "node scripts/testing/run-shard.mjs",
    "test:traceability": "node scripts/testing/generate-traceability-report.mjs",
    "report:performance": "node scripts/testing/generate-performance-report.mjs",
    "report:regression-zero": "node scripts/testing/generate-regression-zero-report.mjs",
    "db:check:all": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:check:all",
    "db:provision:app-role": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:provision:app-role",
    "db:seed:ci": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:seed:ci",
    "db:seed:smoke": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:seed:smoke",
    "db:seed:staging": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:seed:staging",
    "db:validate:pr": "node scripts/ci/run-pnpm.mjs --filter @birthub/database db:validate:pr",
    "release:rollback:evidence": "node --import tsx scripts/release/verify-rollback-evidence.ts",
    "release:rollback:evidence:auto": "node --import tsx scripts/release/materialize-rollback-rehearsal.ts",
    "release:sbom": "node scripts/release/generate-sbom.mjs",
    "release:materialize": "node --import tsx scripts/release/materialize-release.ts",
    "release:bundle": "pnpm release:sbom && pnpm release:materialize",
    "release:verify:cycle0": "bash ./scripts/release/verify-cycle0-flow.sh",
    "release:origin:ensure": "bash ./scripts/release/configure-origin-remote.sh"
  },
  "devDependencies": {
    "@birthub/agents-core": "workspace:*",
    "@birthub/config": "workspace:*",
    "@birthub/database": "workspace:*",
    "@birthub/logger": "workspace:*",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/api": "8.7.1",
    "@playwright/test": "^1.59.1",
    "@prisma/client": "^6.19.2",
    "@types/node": "^25.6.0",
    "bullmq": "^5.73.0",
    "c8": "^10.1.3",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^5.64.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ioredis": "^5.10.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.7",
      "flatted": ">=3.4.2",
      "next": ">=16.1.7",
      "effect": ">=3.20.0",
      "path-to-regexp": "8.4.0",
      "picomatch": "4.0.4",
    "defu": ">=6.1.5",
      "eslint-import-resolver-typescript>unrs-resolver": "npm:empty-npm-package@1.0.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@types/opossum": "^8.1.9",
    "lru-cache": "^11.3.3",
    "opossum": "^9.0.0"
  },
  "description": "Repositório canônico da plataforma SaaS BirthHub 360.",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaarksN/PROJETO-FINAL-BIRTHUB-360-INNOVATION.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MaarksN/PROJETO-FINAL-BIRTHUB-360-INNOVATION/issues"
  },
  "homepage": "https://github.com/MaarksN/PROJETO-FINAL-BIRTHUB-360-INNOVATION#readme"
}
