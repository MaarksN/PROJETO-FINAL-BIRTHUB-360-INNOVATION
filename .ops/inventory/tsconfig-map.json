    "extends": "./tsconfig.json",
    "compilerOptions": {
      "noEmit": true,
      "rootDir": "."
    }
  },
  "packages/workflows-core/tsconfig.json": {
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
      "outDir": "dist/src",
      "rootDir": "src",
      "declaration": true,
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "baseUrl": ".",
      "paths": {},
      "types": [
        "node"
      ]
    }
  },
  "tsconfig.base.json": {
    "compilerOptions": {
      "target": "ES2022",
      "lib": [
        "ES2022",
        "DOM"
      ],
      "module": "commonjs",
      "moduleResolution": "node",
      "strict": true,
      "noImplicitAny": true,
      "noUncheckedIndexedAccess": true,
      "exactOptionalPropertyTypes": true,
      "noImplicitOverride": true,
      "declaration": false,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "resolveJsonModule": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "baseUrl": ".",
      "paths": {
        "@birthub/agents-core": [
          "packages/agents-core/src/index.ts"
        ],
        "@birthub/agents-core/tools": [
          "packages/agents-core/src/tools/index.ts"
        ],
        "@birthub/agents-core/tools/*": [
          "packages/agents-core/src/tools/*.ts"
        ],
        "@birthub/agents-core/policy/*": [
          "packages/agents-core/src/policy/*.ts"
        ],
        "@birthub/agents-core/*": [
          "packages/agents-core/src/*"
        ],
        "@birthub/agents-registry": [
          "packages/agents-registry/src/index.ts"
        ],
        "@birthub/agents-registry/*": [
          "packages/agents-registry/src/*"
        ],
        "@birthub/database": [
          "packages/database/src/index.ts"
        ],
        "@birthub/database/*": [
          "packages/database/src/*"
        ],
        "@birthub/config": [
          "packages/config/src/index.ts"
        ],
        "@birthub/config/web": [
          "packages/config/src/web.ts"
        ],
        "@birthub/config/*": [
          "packages/config/src/*"
        ],
        "@birthub/logger": [
          "packages/logger/src/index.ts"
        ],
        "@birthub/logger/*": [
          "packages/logger/src/*"
        ],
        "@birthub/testing": [
          "packages/testing/src/index.ts"
        ],
        "@birthub/testing/*": [
          "packages/testing/src/*"
        ],
        "@birthub/workflows-core": [
          "packages/workflows-core/src/index.ts"
        ],
        "@birthub/workflows-core/nextjs": [
          "packages/workflows-core/src/nextjs.ts"
        ],
        "@birthub/workflows-core/*": [
          "packages/workflows-core/src/*"
        ],
        "@birthub/*": [
          "packages/*/src/index.ts",
          "packages/*/src",
          "packages/*"
        ]
      }
    }
  },
  "tsconfig.json": {
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
      "allowJs": true,
      "noEmit": true,
      "module": "esnext",
      "moduleResolution": "node",
      "isolatedModules": true,
      "jsx": "preserve",
      "incremental": true
    }
  }
}