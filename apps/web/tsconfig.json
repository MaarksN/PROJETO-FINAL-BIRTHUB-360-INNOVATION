{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "allowImportingTsExtensions": true,
    "incremental": false,
    "moduleResolution": "bundler",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
