{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".", "exactOptionalPropertyTypes": false, "noImplicitAny": false, "useUnknownInCatchVariables": false, "strict": false, "skipLibCheck": true,
    "paths": { "@birthub/*": ["../../packages/*", "../packages/*", "./packages/*"] },
    "allowImportingTsExtensions": true,
    "incremental": false,
    "moduleResolution": "bundler",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
