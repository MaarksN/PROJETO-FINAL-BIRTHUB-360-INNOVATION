{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "exactOptionalPropertyTypes": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "strict": false,
    "skipLibCheck": true,
    "paths": {
      "@birthub/agents-core": [
        "../../packages/agents-core/src/index.ts"
      ],
      "@birthub/agents-core/*": [
        "../../packages/agents-core/src/*"
      ],
      "@birthub/config": [
        "../../packages/config/src/index.ts"
      ],
      "@birthub/config/web": [
        "../../packages/config/src/web.ts"
      ],
      "@birthub/database": [
        "../../packages/database/src/index.ts"
      ],
      "@birthub/database/*": [
        "../../packages/database/src/*"
      ],
      "@birthub/logger": [
        "../../packages/logger/src/index.ts"
      ],
      "@birthub/logger/*": [
        "../../packages/logger/src/*"
      ],
      "@birthub/queue": [
        "../../packages/queue/src/index.ts"
      ],
      "@birthub/queue/*": [
        "../../packages/queue/src/*"
      ],
      "@birthub/shared-types": [
        "../../packages/shared-types/src/index.ts"
      ],
      "@birthub/shared-types/*": [
        "../../packages/shared-types/src/*"
      ],
      "@birthub/testing": [
        "../../packages/testing/src/index.ts"
      ],
      "@birthub/testing/*": [
        "../../packages/testing/src/*"
      ],
      "@birthub/workflows-core": [
        "../../packages/workflows-core/src/index.ts"
      ],
      "@birthub/workflows-core/*": [
        "../../packages/workflows-core/src/*"
      ],
      "@birthub/*": [
        "../../packages/*/src",
        "../packages/*/src",
        "./packages/*/src"
      ]
    },
    "outDir": "dist",
    "declaration": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ]
  },
  "include": [
    "./src/**/*.d.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "tests",
    "test",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx"
  ]
}