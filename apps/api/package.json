{
  "name": "@birthub/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint .",
    "start": "node dist/src/server.js",
    "test:auth": "node --import tsx --test tests/auth.test.ts",
    "test:rbac": "node --import tsx --test tests/rbac.test.ts",
    "test:security": "node --import tsx --test tests/security.test.ts",
    "test": "node --import tsx --test tests/**/*.test.ts test/**/*.test.ts",
    "test:isolation": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.2.0",
    "@birthub/agents-core": "workspace:*",
    "@birthub/config": "workspace:*",
    "@birthub/database": "workspace:*",
    "@birthub/logger": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@prisma/instrumentation": "^6.2.1",
    "@sentry/node": "^8.48.0",
    "bullmq": "^5.34.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
