{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": { "@birthub/*": ["../../packages/*", "../packages/*", "./packages/*"] },
    "noImplicitAny": false, "useUnknownInCatchVariables": false, "strict": false, "skipLibCheck": true,

    "outDir": "dist",
    "declaration": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ]
  },
  "include": ["./src/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
